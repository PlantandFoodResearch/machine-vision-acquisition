{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: viewer",
            "type": "python",
            "request": "launch",
            "module": "machine_vision_acquisition_python.viewer",
            "args": [
                "--all",
                "--tof=false",
                "--out-dir",
                "/output/tmp/"
            ],
            "justMyCode": true,
            "env": {
                "DISPLAY": ""
            }
        },
        {
            "name": "Python: datacapture",
            "type": "python",
            "request": "launch",
            "module": "machine_vision_acquisition_python.datacapture",
            "args": [
                "--config",
                "${workspaceFolder}/"
            ],
            "justMyCode": true,
            "env": {
                "DISPLAY": ""
            }
        },
        {
            "name": "Python: TOF viewer",
            "type": "python",
            "request": "launch",
            "module": "machine_vision_acquisition_python.viewer.tof",
            "args": ["--serial", "2020029"],
            "env": {
                "DISPLAY": "localhost:10.0",
                "LIBGL_ALWAYS_INDIRECT": "1"
            },
            "justMyCode": true
        },
        {
            "name": "Python: nmcli-dhcp-manager",
            "type": "python",
            "request": "launch",
            "program": "src/utils/nmcli-dhcp-manager.py",
            "args": ["--devices=enp4s0,"],
            "justMyCode": true,
        },
    ]
}